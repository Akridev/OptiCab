{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/recommendation.js": {
      "maxDuration": 30
    },
    "api/fares.js": {
      "maxDuration": 10
    },
    "api/stripe-checkout.js": {
      "maxDuration": 10
    },
    "api/create-payment.js": {
      "maxDuration": 10
    },
    "api/payment-form.js": {
      "maxDuration": 5
    },
    "api/stripe-webhook.js": {
      "maxDuration": 10
    },
    "api/subscription-status.js": {
      "maxDuration": 10
    },
    "api/saved-routes.js": {
      "maxDuration": 10
    },
    "api/ride-history.js": {
      "maxDuration": 10
    },
    "api/fare-refresh.js": {
      "maxDuration": 15
    }
  }
}
